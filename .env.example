PIPELINER_ENV=development
PIPELINER_DATA_DIR=.pipeliner
PIPELINER_DEFAULT_TIMEOUT=30m
PIPELINER_DEFAULT_MAX_REWORK_ROUNDS=3
PIPELINER_BLOCKED_REQUIRES_MANUAL=true
PIPELINER_FAILURE_REQUIRES_MANUAL=true
PIPELINER_CLAUDE_EXECUTOR_CMD="claude -p --permission-mode bypassPermissions"
PIPELINER_CLAUDE_VALIDATOR_CMD="claude -p --permission-mode bypassPermissions"
PIPELINER_API_HOST=127.0.0.1
PIPELINER_API_PORT=8000
PIPELINER_WEB_PORT=3000
PIPELINER_API_BASE_URL=http://127.0.0.1:8000
