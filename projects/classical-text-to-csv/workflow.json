{
  "schema_version": "pipeliner.workflow/v1alpha1",
  "metadata": {
    "workflow_id": "classical-text-to-csv",
    "title": "古籍文本整理自动工作流",
    "purpose": "将整部古籍文本处理成标准格式的 CSV 文件。为避免结构识别阶段直接吞整本书导致长时间无输出，工作流会先对预处理后的全文进行切块，生成一组顺序文档，每个文档不超过 20000 字，再基于这些切块做篇章线索扫描、结构定稿、按篇章拆文档和后续批量处理。",
    "version": "0.5.1",
    "tags": [
      "classical-text",
      "csv-generation",
      "text-processing",
      "batch-processing",
      "chunked-outline"
    ]
  },
  "inputs": [
    {
      "name": "source_text",
      "shape": "file",
      "required": true,
      "summary": "原始文本文档路径，包含需要处理的完整古籍文本内容"
    },
    {
      "name": "work_title",
      "shape": "string",
      "required": true,
      "summary": "著作标题，CSV 必填字段"
    },
    {
      "name": "author",
      "shape": "string",
      "required": false,
      "summary": "作者名称，可选"
    },
    {
      "name": "work_type",
      "shape": "string",
      "required": false,
      "summary": "著作类型：原著/作者合集/朝代选集/主题选集，默认 original"
    },
    {
      "name": "category",
      "shape": "string",
      "required": false,
      "summary": "内容分类：诗/词/散文/论著/综合，默认 poetry"
    },
    {
      "name": "era",
      "shape": "string",
      "required": false,
      "summary": "朝代信息，可选"
    },
    {
      "name": "description",
      "shape": "string",
      "required": false,
      "summary": "著作简介，可选"
    },
    {
      "name": "structure_hint",
      "shape": "string",
      "required": false,
      "summary": "篇章结构提示，可选。如“共 12 卷”“常见标题含序、跋、卷一”等"
    }
  ],
  "outputs": [
    {
      "name": "output_csv",
      "from": {
        "node_id": "final_validation",
        "output": "validated_csv"
      },
      "shape": "file",
      "required": true,
      "summary": "最终生成并通过验证的标准格式 CSV 文件"
    },
    {
      "name": "processing_report",
      "from": {
        "node_id": "final_validation",
        "output": "report"
      },
      "shape": "file",
      "required": false,
      "summary": "处理报告，包含结构识别、切块、分段和质量检查摘要"
    }
  ],
  "nodes": [
    {
      "node_id": "text_preprocessing",
      "title": "文本预处理",
      "purpose": "对原始文本进行 OCR 错误修正和格式整理，修复明显的格式错误、特殊符号和标点重复等问题，但保持原文内容完整不遗漏",
      "archetype": "preprocess-content",
      "depends_on": [],
      "inputs": [
        {
          "name": "source_text",
          "from": {
            "kind": "workflow_input",
            "name": "source_text"
          },
          "shape": "file",
          "required": true,
          "summary": "原始文本文档"
        }
      ],
      "outputs": [
        {
          "name": "preprocessed_text",
          "shape": "file",
          "summary": "预处理后的文本，修正 OCR 错误和格式问题"
        }
      ],
      "executor": {
        "skill": "classical-text-preprocess"
      },
      "validators": [
        {
          "validator_id": "ocr-correction-check",
          "skill": "ocr-correction-validator"
        }
      ],
      "acceptance": {
        "done_means": "文本已完成 OCR 错误修正和基本格式整理",
        "pass_condition": [
          "已修复明显的 OCR 识别错误",
          "已整理格式错误和特殊符号重复",
          "原文内容无遗漏、无错误修改"
        ]
      },
      "gate": {
        "mode": "all_validators_pass"
      },
      "handoff": {
        "outputs": [
          "preprocessed_text"
        ]
      }
    },
    {
      "node_id": "text_chunking",
      "title": "全文切块",
      "purpose": "将预处理后的全文按顺序切分为一组连续文档，优先沿自然段、空行或明显结构边界切开，确保每个切块文档不超过 20000 字，为后续结构识别提供稳定输入",
      "archetype": "split-content",
      "depends_on": [
        "text_preprocessing"
      ],
      "inputs": [
        {
          "name": "preprocessed_text",
          "from": {
            "kind": "node_output",
            "node_id": "text_preprocessing",
            "output": "preprocessed_text"
          },
          "shape": "file",
          "required": true,
          "summary": "预处理后的完整文本"
        },
        {
          "name": "structure_hint",
          "from": {
            "kind": "workflow_input",
            "name": "structure_hint"
          },
          "shape": "string",
          "required": false,
          "summary": "可选切块提示，帮助尽量在潜在结构边界附近切开"
        }
      ],
      "outputs": [
        {
          "name": "text_chunks_dir",
          "shape": "directory",
          "summary": "全文切块目录，包含顺序编号的切块文档"
        },
        {
          "name": "chunk_manifest",
          "shape": "structured_data",
          "summary": "切块清单，记录每个切块的顺序、字符范围、文件名和长度"
        }
      ],
      "executor": {
        "skill": "text-chunking"
      },
      "validators": [
        {
          "validator_id": "text-chunking-check",
          "skill": "text-chunking-validator"
        }
      ],
      "acceptance": {
        "done_means": "全文已切分为连续切块文档，可安全进入后续结构识别",
        "pass_condition": [
          "每个切块文档长度不超过 20000 字",
          "切块顺序与原文顺序严格一致",
          "所有原文内容都被覆盖且没有重复",
          "切块清单包含字符范围、长度和文件路径"
        ]
      },
      "gate": {
        "mode": "all_validators_pass"
      },
      "handoff": {
        "outputs": [
          "text_chunks_dir",
          "chunk_manifest"
        ]
      }
    },
    {
      "node_id": "chapter_outline_scan",
      "title": "篇章线索扫描",
      "purpose": "逐个读取切块文档，提取局部章节标题、边界和结构线索，再汇总为全书级候选结构，避免结构识别阶段直接处理整本书",
      "archetype": "recognize-structure",
      "depends_on": [
        "text_chunking"
      ],
      "inputs": [
        {
          "name": "text_chunks_dir",
          "from": {
            "kind": "node_output",
            "node_id": "text_chunking",
            "output": "text_chunks_dir"
          },
          "shape": "directory",
          "required": true,
          "summary": "按顺序切分后的全文切块目录"
        },
        {
          "name": "chunk_manifest",
          "from": {
            "kind": "node_output",
            "node_id": "text_chunking",
            "output": "chunk_manifest"
          },
          "shape": "structured_data",
          "required": true,
          "summary": "切块清单，帮助将局部线索映射回全书位置"
        },
        {
          "name": "structure_hint",
          "from": {
            "kind": "workflow_input",
            "name": "structure_hint"
          },
          "shape": "string",
          "required": false,
          "summary": "篇章结构提示，帮助更快识别候选章节边界"
        }
      ],
      "outputs": [
        {
          "name": "chapter_outline_candidates",
          "shape": "structured_data",
          "summary": "候选章节标题、边界、来源切块和结构线索列表"
        }
      ],
      "executor": {
        "skill": "chapter-outline-scan"
      },
      "validators": [
        {
          "validator_id": "chapter-outline-check",
          "skill": "chapter-outline-validator"
        }
      ],
      "acceptance": {
        "done_means": "已提取出可靠的候选章节边界和标题线索",
        "pass_condition": [
          "至少识别出全书的主要结构线索",
          "候选边界覆盖所有切块，不出现明显大片遗漏",
          "每条候选线索都能映射回来源切块和全书位置",
          "标题和边界信息足以支持下一步定稿"
        ]
      },
      "gate": {
        "mode": "all_validators_pass"
      },
      "handoff": {
        "outputs": [
          "chapter_outline_candidates"
        ]
      }
    },
    {
      "node_id": "chapter_structure_finalize",
      "title": "篇章结构定稿与文档拆分",
      "purpose": "基于切块清单、候选章节线索和预处理全文，生成最终的结构化章节列表，并将原始文本按照篇章划分为单独的文档文件（一篇章一个文档），供后续批量处理",
      "archetype": "recognize-structure",
      "depends_on": [
        "text_preprocessing",
        "text_chunking",
        "chapter_outline_scan"
      ],
      "inputs": [
        {
          "name": "preprocessed_text",
          "from": {
            "kind": "node_output",
            "node_id": "text_preprocessing",
            "output": "preprocessed_text"
          },
          "shape": "file",
          "required": true,
          "summary": "预处理后的全文"
        },
        {
          "name": "text_chunks_dir",
          "from": {
            "kind": "node_output",
            "node_id": "text_chunking",
            "output": "text_chunks_dir"
          },
          "shape": "directory",
          "required": true,
          "summary": "全文切块目录，供核对局部线索与原文上下文"
        },
        {
          "name": "chunk_manifest",
          "from": {
            "kind": "node_output",
            "node_id": "text_chunking",
            "output": "chunk_manifest"
          },
          "shape": "structured_data",
          "required": true,
          "summary": "切块清单，帮助将候选边界回写为全书连续范围"
        },
        {
          "name": "chapter_outline_candidates",
          "from": {
            "kind": "node_output",
            "node_id": "chapter_outline_scan",
            "output": "chapter_outline_candidates"
          },
          "shape": "structured_data",
          "required": true,
          "summary": "候选章节边界和标题线索"
        },
        {
          "name": "structure_hint",
          "from": {
            "kind": "workflow_input",
            "name": "structure_hint"
          },
          "shape": "string",
          "required": false,
          "summary": "篇章结构提示，帮助最终定稿"
        }
      ],
      "outputs": [
        {
          "name": "chapters_structure",
          "shape": "structured_data",
          "summary": "最终识别出的篇章结构列表，每个篇章包含标题、类型和内容范围"
        },
        {
          "name": "chapter_files_dir",
          "shape": "directory",
          "summary": "篇章文档目录，每个篇章保存为单独的文本文件"
        }
      ],
      "executor": {
        "skill": "chapter-structure-finalizer"
      },
      "validators": [
        {
          "validator_id": "chapter-structure-check",
          "skill": "chapter-structure-validator"
        }
      ],
      "acceptance": {
        "done_means": "已生成最终章节结构并将每篇章保存为单独文档文件",
        "pass_condition": [
          "篇章划分合理，符合文本结构特征",
          "每个篇章都有明确标题",
          "篇章之间无重叠、无遗漏",
          "原文所有内容都被分配到相应篇章",
          "每篇章已保存为单独的文档文件"
        ]
      },
      "gate": {
        "mode": "all_validators_pass"
      },
      "handoff": {
        "outputs": [
          "chapters_structure",
          "chapter_files_dir"
        ]
      }
    },
    {
      "node_id": "chapter_batch_segmentation",
      "title": "批量语义分段",
      "purpose": "对每个篇章文档进行批量语义分段处理，根据语义块将每个篇章内容合理分段，每段包含 3-5 句话或一个完整的语义块，不基于原始换行符机械分段",
      "archetype": "segment-content",
      "depends_on": [
        "chapter_structure_finalize"
      ],
      "inputs": [
        {
          "name": "chapter_files_dir",
          "from": {
            "kind": "node_output",
            "node_id": "chapter_structure_finalize",
            "output": "chapter_files_dir"
          },
          "shape": "directory",
          "required": true,
          "summary": "篇章文档目录，包含每个篇章的单独文本文件"
        },
        {
          "name": "chapters_structure",
          "from": {
            "kind": "node_output",
            "node_id": "chapter_structure_finalize",
            "output": "chapters_structure"
          },
          "shape": "structured_data",
          "required": true,
          "summary": "篇章结构信息，用于指导分段处理"
        }
      ],
      "outputs": [
        {
          "name": "segmented_chapters_dir",
          "shape": "directory",
          "summary": "语义分段后的篇章文档目录，每篇章包含多个段落及其序号"
        },
        {
          "name": "segmentation_manifest",
          "shape": "structured_data",
          "summary": "分段处理清单，记录每个篇章的分段统计信息"
        }
      ],
      "executor": {
        "skill": "chapter-batch-segmentation"
      },
      "validators": [
        {
          "validator_id": "batch-segmentation-check",
          "skill": "batch-segmentation-validator"
        },
        {
          "validator_id": "content-integrity-check",
          "skill": "content-integrity-validator"
        }
      ],
      "acceptance": {
        "done_means": "所有篇章文档已按语义块合理分段，每段 3-5 句话或一个完整语义单元",
        "pass_condition": [
          "分段基于语义而非原始换行符",
          "每段长度适中（3-5 句话或一个语义块）",
          "原文内容无遗漏、无错误修改",
          "各篇章内的段落序号连续正确",
          "所有篇章文档都已处理完成"
        ]
      },
      "gate": {
        "mode": "all_validators_pass"
      },
      "handoff": {
        "outputs": [
          "segmented_chapters_dir",
          "segmentation_manifest"
        ]
      }
    },
    {
      "node_id": "chapter_batch_analysis",
      "title": "批量结构分析与元数据整合",
      "purpose": "对分段后的篇章文档进行批量元数据整合处理，包括整合作品标题、篇章标题、作者、朝代、作品类型、内容分类和篇章类型等，为 CSV 生成准备完整数据结构",
      "archetype": "analyze-structure",
      "depends_on": [
        "chapter_batch_segmentation"
      ],
      "inputs": [
        {
          "name": "segmented_chapters_dir",
          "from": {
            "kind": "node_output",
            "node_id": "chapter_batch_segmentation",
            "output": "segmented_chapters_dir"
          },
          "shape": "directory",
          "required": true,
          "summary": "语义分段后的篇章文档目录"
        },
        {
          "name": "segmentation_manifest",
          "from": {
            "kind": "node_output",
            "node_id": "chapter_batch_segmentation",
            "output": "segmentation_manifest"
          },
          "shape": "structured_data",
          "required": true,
          "summary": "分段处理清单"
        },
        {
          "name": "work_title",
          "from": {
            "kind": "workflow_input",
            "name": "work_title"
          },
          "shape": "string",
          "required": true,
          "summary": "著作标题"
        },
        {
          "name": "author",
          "from": {
            "kind": "workflow_input",
            "name": "author"
          },
          "shape": "string",
          "required": false,
          "summary": "作者"
        },
        {
          "name": "work_type",
          "from": {
            "kind": "workflow_input",
            "name": "work_type"
          },
          "shape": "string",
          "required": false,
          "summary": "著作类型"
        },
        {
          "name": "category",
          "from": {
            "kind": "workflow_input",
            "name": "category"
          },
          "shape": "string",
          "required": false,
          "summary": "内容分类"
        },
        {
          "name": "era",
          "from": {
            "kind": "workflow_input",
            "name": "era"
          },
          "shape": "string",
          "required": false,
          "summary": "朝代"
        },
        {
          "name": "description",
          "from": {
            "kind": "workflow_input",
            "name": "description"
          },
          "shape": "string",
          "required": false,
          "summary": "著作简介"
        }
      ],
      "outputs": [
        {
          "name": "structured_data_dir",
          "shape": "directory",
          "summary": "包含完整元数据的结构化数据文档目录"
        },
        {
          "name": "analysis_manifest",
          "shape": "structured_data",
          "summary": "分析处理清单，记录每个篇章的元数据整合结果"
        }
      ],
      "executor": {
        "skill": "chapter-batch-analysis"
      },
      "validators": [
        {
          "validator_id": "batch-analysis-check",
          "skill": "batch-analysis-validator"
        },
        {
          "validator_id": "structure-completeness-check",
          "skill": "structure-completeness-validator"
        }
      ],
      "acceptance": {
        "done_means": "已对所有篇章文档完成元数据整合，数据结构符合 CSV 生成要求",
        "pass_condition": [
          "著作标题已正确设置",
          "各篇章标题已正确提取",
          "所有元数据字段已按规则整合",
          "各篇章内段落序号连续无重复",
          "所有篇章文档的元数据都已处理完成",
          "数据结构符合 CSV 生成要求"
        ]
      },
      "gate": {
        "mode": "all_validators_pass"
      },
      "handoff": {
        "outputs": [
          "structured_data_dir",
          "analysis_manifest"
        ]
      }
    },
    {
      "node_id": "csv_generation",
      "title": "CSV 文件生成",
      "purpose": "按照标准格式要求生成 CSV 文件，将所有篇章的结构化数据合并、排序、汇总为单个 CSV 文件，确保编码为 UTF-8，分隔符为英文逗号",
      "archetype": "generate-output",
      "depends_on": [
        "chapter_batch_analysis"
      ],
      "inputs": [
        {
          "name": "structured_data_dir",
          "from": {
            "kind": "node_output",
            "node_id": "chapter_batch_analysis",
            "output": "structured_data_dir"
          },
          "shape": "directory",
          "required": true,
          "summary": "包含完整元数据的结构化数据文档目录"
        },
        {
          "name": "analysis_manifest",
          "from": {
            "kind": "node_output",
            "node_id": "chapter_batch_analysis",
            "output": "analysis_manifest"
          },
          "shape": "structured_data",
          "required": true,
          "summary": "分析处理清单，用于验证数据完整性"
        }
      ],
      "outputs": [
        {
          "name": "csv_file",
          "shape": "file",
          "summary": "生成的标准格式 CSV 文件"
        }
      ],
      "executor": {
        "skill": "classical-csv-generator"
      },
      "validators": [
        {
          "validator_id": "csv-format-check",
          "skill": "csv-format-validator"
        },
        {
          "validator_id": "csv-schema-check",
          "skill": "csv-schema-validator"
        }
      ],
      "acceptance": {
        "done_means": "已生成符合标准格式的 CSV 文件",
        "pass_condition": [
          "CSV 编码为 UTF-8",
          "表头包含所有必填字段",
          "分隔符为英文逗号",
          "段落序号可正确转为整数",
          "数据行与输入段落一致",
          "各篇章数据完整无遗漏"
        ]
      },
      "gate": {
        "mode": "all_validators_pass"
      },
      "handoff": {
        "outputs": [
          "csv_file"
        ]
      }
    },
    {
      "node_id": "final_validation",
      "title": "最终质量验证",
      "purpose": "对生成的 CSV 进行全面的质量检查，包括内容完整性验证、格式规范验证、篇章结构验证，并生成处理报告",
      "archetype": "validate-output",
      "depends_on": [
        "csv_generation",
        "chapter_batch_segmentation"
      ],
      "inputs": [
        {
          "name": "csv_file",
          "from": {
            "kind": "node_output",
            "node_id": "csv_generation",
            "output": "csv_file"
          },
          "shape": "file",
          "required": true,
          "summary": "生成的 CSV 文件"
        },
        {
          "name": "segmentation_manifest",
          "from": {
            "kind": "node_output",
            "node_id": "chapter_batch_segmentation",
            "output": "segmentation_manifest"
          },
          "shape": "structured_data",
          "required": true,
          "summary": "分段处理清单，用于比对验证"
        }
      ],
      "outputs": [
        {
          "name": "validated_csv",
          "shape": "file",
          "summary": "验证通过的 CSV 文件"
        },
        {
          "name": "report",
          "shape": "file",
          "summary": "处理报告，包含结构识别、切块统计、分段统计和质量检查结果"
        }
      ],
      "executor": {
        "skill": "output-validator"
      },
      "validators": [
        {
          "validator_id": "completeness-check",
          "skill": "completeness-validator"
        },
        {
          "validator_id": "quality-check",
          "skill": "quality-validator"
        }
      ],
      "acceptance": {
        "done_means": "CSV 文件已通过全面质量验证",
        "pass_condition": [
          "原文内容无遗漏",
          "无错误修改",
          "格式完全符合规范",
          "段落序号连续无重复",
          "元数据完整准确",
          "各篇章结构清晰完整"
        ]
      },
      "gate": {
        "mode": "all_validators_pass"
      },
      "handoff": {
        "outputs": [
          "validated_csv",
          "report"
        ]
      }
    }
  ],
  "defaults": {
    "runtime_guards": {
      "timeout": "2h",
      "first_byte_timeout": "180s",
      "max_rework_rounds": 6,
      "blocked_requires_manual": true,
      "failure_requires_manual": true
    }
  },
  "extensions": {}
}
