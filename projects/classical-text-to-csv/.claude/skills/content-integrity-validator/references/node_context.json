{
  "workflow": {
    "workflow_id": "classical-text-to-csv",
    "title": "古籍文本整理自动工作流",
    "version": "0.2.0"
  },
  "skill": {
    "name": "content-integrity-validator",
    "role": "validator",
    "validator_id": "content-integrity-check"
  },
  "node_id": "semantic_segmentation",
  "node_spec": {
    "node_id": "semantic_segmentation",
    "title": "语义分段",
    "purpose": "根据语义块对每个篇章的内容进行合理分段，每段包含 3-5 句话或一个完整的语义块，不基于原始换行符机械分段，确保段落便于后续阅读时比对翻译",
    "archetype": "segment-content",
    "depends_on": [
      "chapter_recognition"
    ],
    "inputs": [
      {
        "name": "chapters_structure",
        "from": {
          "kind": "node_output",
          "name": null,
          "node_id": "chapter_recognition",
          "output": "chapters_structure"
        },
        "shape": "structured_data",
        "required": true,
        "summary": "识别出的篇章结构列表"
      }
    ],
    "outputs": [
      {
        "name": "segmented_chapters",
        "shape": "structured_data",
        "summary": "语义分段后的篇章列表，每个篇章包含多个段落，每段有序号和内容"
      }
    ],
    "executor": {
      "skill": "semantic-text-segmentation"
    },
    "validators": [
      {
        "validator_id": "segmentation-quality-check",
        "skill": "segmentation-quality-validator"
      },
      {
        "validator_id": "content-integrity-check",
        "skill": "content-integrity-validator"
      }
    ],
    "acceptance": {
      "done_means": "所有篇章的文本已按语义块合理分段，每段 3-5 句话或一个完整语义单元",
      "pass_condition": [
        "分段基于语义而非原始换行符",
        "每段长度适中（3-5 句话或一个语义块）",
        "原文内容无遗漏、无错误修改",
        "各篇章内的段落序号连续正确"
      ]
    },
    "gate": {
      "mode": "all_validators_pass"
    },
    "handoff": {
      "outputs": [
        "segmented_chapters"
      ]
    }
  },
  "updated_at": "2026-03-13T02:10:44.027586+00:00"
