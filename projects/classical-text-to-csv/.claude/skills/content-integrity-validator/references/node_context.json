{
  "workflow": {
    "workflow_id": "classical-text-to-csv",
    "title": "古籍文本整理自动工作流",
    "version": "0.5.2"
  },
  "skill": {
    "name": "content-integrity-validator",
    "role": "validator",
    "validator_id": "content-integrity-check"
  },
  "node_id": "chapter_batch_segmentation",
  "node_spec": {
    "node_id": "chapter_batch_segmentation",
    "title": "批量语义分段",
    "purpose": "对每个篇章文档进行批量语义分段处理，根据语义块将每个篇章内容合理分段，每段包含 1-5 句话（不超过 5 句），且每段必须在完整句子结尾处截止，绝不在句子中间分割，输出纯文本段落不含任何 JSON 符号",
    "archetype": "segment-content",
    "depends_on": [
      "chapter_structure_finalize"
    ],
    "inputs": [
      {
        "name": "chapter_files_dir",
        "from": {
          "kind": "node_output",
          "name": null,
          "node_id": "chapter_structure_finalize",
          "output": "chapter_files_dir"
        },
        "shape": "directory",
        "required": true,
        "summary": "篇章文档目录，包含每个篇章的单独文本文件"
      },
      {
        "name": "chapters_structure",
        "from": {
          "kind": "node_output",
          "name": null,
          "node_id": "chapter_structure_finalize",
          "output": "chapters_structure"
        },
        "shape": "structured_data",
        "required": true,
        "summary": "篇章结构信息，用于指导分段处理"
      }
    ],
    "outputs": [
      {
        "name": "segmented_chapters_dir",
        "shape": "directory",
        "summary": "语义分段后的篇章文档目录，每篇章包含多个段落及其序号"
      },
      {
        "name": "segmentation_manifest",
        "shape": "structured_data",
        "summary": "分段处理清单，记录每个篇章的分段统计信息"
      }
    ],
    "executor": {
      "skill": "chapter-batch-segmentation"
    },
    "validators": [
      {
        "validator_id": "batch-segmentation-check",
        "skill": "batch-segmentation-validator"
      },
      {
        "validator_id": "content-integrity-check",
        "skill": "content-integrity-validator"
      }
    ],
    "acceptance": {
      "done_means": "所有篇章文档已按语义块合理分段，每段不超过 5 句话，无句中截断，无 JSON 符号污染",
      "pass_condition": [
        "分段基于语义而非原始换行符",
        "每段不超过 5 句话，超出 5 句话的段落必须进一步拆分",
        "每段必须在完整句子结尾（。！？…）处截止，不允许在句子中间截断",
        "段落内容为纯文本，不含 {}[] 等 JSON/程序语法符号",
        "原文内容无遗漏、无错误修改",
        "各篇章内的段落序号连续正确",
        "所有篇章文档都已处理完成"
      ]
    },
    "gate": {
      "mode": "all_validators_pass"
    },
    "handoff": {
      "outputs": [
        "segmented_chapters_dir",
        "segmentation_manifest"
      ]
    }
  },
  "updated_at": "2026-03-20T07:51:46.576223+00:00"
}