  "node_spec": {
    "node_id": "csv_generation",
    "title": "CSV 文件生成",
    "purpose": "按照标准格式要求生成 CSV 文件，将所有篇章的结构化数据合并、排序、汇总为单个 CSV 文件，确保编码为 UTF-8，分隔符为英文逗号",
    "archetype": "generate-output",
    "depends_on": [
      "chapter_batch_analysis"
    ],
    "inputs": [
      {
        "name": "structured_data_dir",
        "from": {
          "kind": "node_output",
          "name": null,
          "node_id": "chapter_batch_analysis",
          "output": "structured_data_dir"
        },
        "shape": "directory",
        "required": true,
        "summary": "包含完整元数据的结构化数据文档目录"
      },
      {
        "name": "analysis_manifest",
        "from": {
          "kind": "node_output",
          "name": null,
          "node_id": "chapter_batch_analysis",
          "output": "analysis_manifest"
        },
        "shape": "structured_data",
        "required": true,
        "summary": "分析处理清单，用于验证数据完整性"
      }
    ],
    "outputs": [
      {
        "name": "csv_file",
        "shape": "file",
        "summary": "生成的标准格式 CSV 文件"
      }
    ],
    "executor": {
      "skill": "classical-csv-generator"
    },
    "validators": [
      {
        "validator_id": "csv-format-check",
        "skill": "csv-format-validator"
      },
      {
        "validator_id": "csv-schema-check",
        "skill": "csv-schema-validator"
      }
    ],
    "acceptance": {
      "done_means": "已生成符合标准格式的 CSV 文件",
      "pass_condition": [
        "CSV 编码为 UTF-8",
        "表头包含所有必填字段",
        "分隔符为英文逗号",
        "段落序号可正确转为整数",
        "数据行与输入段落一致",
        "各篇章数据完整无遗漏"
      ]
    },
    "gate": {
      "mode": "all_validators_pass"
    },
    "handoff": {
      "outputs": [
        "csv_file"
      ]
    }
